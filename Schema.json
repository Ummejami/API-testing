// New version for validation schema

const schema1 = {
    type: "object",
    properties: {
        id: { type: "string" },
        name: { type: "string" },
        location: { type: "string" },
        phone: { type: "string" },
        courses: {
            type: "array",
            items: {
                type: "string"
            }
        }
    },
    required: ["id", "name", "location", "phone", "courses"]
};

pm.test("Test schema validation", () => {
    pm.response.to.have.jsonSchema(schema1);
});

